# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

# Internal Photon URL. Points at the public Photon demo for now so the gateway
# works before the photon container exists; switch to http://photon:2322 once
# the photon service is wired up in compose.
PHOTON_URL=https://photon.komoot.io
# Internal OSRM URL. Points at the public OSRM demo for now so the gateway
# works before the osrm container exists; switch to http://osrm:5000 once
# the osrm service is wired up in compose.
OSRM_URL=https://router.project-osrm.org
# Default result language (Photon `lang`).
DEFAULT_LANG=de
# The one knob. Selects the Photon prebuilt index (de / germany / europe / ...) and,
# via osrm/build.sh, the Geofabrik extract baked into the OSRM graph — so both cover
# the same area. Passed to gateway, photon and osrm-init from this single place.
REGION=de
# OSRM routing profile: car, bicycle or foot.
OSRM_PROFILE=car
# Override the auto-derived Geofabrik .osm.pbf URL for a region not in the build map.
# GEOFABRIK_URL=
# Cache lifetime in seconds for geocoding and routing lookups.
CACHE_TTL=86400
# Caching backend. Filesystem by default (no extra services). Set to true/1/yes
# to use the in-cluster Redis instead; anything else (or unset) stays filesystem.
ENABLE_REDIS=true
# Internal Redis DSN; the operator never sets this. Inside Compose the Redis host
# is always "redis", so the default works as-is. ENABLE_REDIS is the only knob.
REDIS_URL=redis://redis:6379
# Plumbing — maps ENABLE_REDIS onto a Compose profile so the redis service (tagged
# profiles: ["true"]) starts only when ENABLE_REDIS=true; false/unset starts everything
# else. Relies on .env interpolation (recent Docker Compose v2). Leave this as-is.
COMPOSE_PROFILES=${ENABLE_REDIS:-false}
# CORS origin(s) allowed for browser autocomplete. "*" allows any origin; set a
# concrete origin (or regex) to restrict it.
CORS_ALLOW_ORIGIN=*
# Optional API key. When set, every request (except /health) must send it via the
# "X-API-Key" header. Empty leaves the API open.
API_KEY=1234
