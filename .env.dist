# ─────────────────────────────────────────────────────────────────────────────
# geo-microservice — operator configuration template
#
# Copy the values you want to change into a local, uncommitted `.env.local`
# (or edit `.env`). Every variable below has a working default, so the only
# thing you *have* to decide is REGION. The promise is: set REGION, then
# `docker compose up` — Photon and OSRM import their data automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── The one knob ────────────────────────────────────────────────────────────
# Selects BOTH the Photon prebuilt index and (via osrm/build.sh) the Geofabrik
# extract baked into the OSRM graph, so the geocoder and router always cover the
# same area. Built-in values: de/germany, at/austria, fr/france, nl/netherlands,
# es/spain, it/italy, ch/switzerland, be/belgium, pl/poland, europe.
# For anything else, set GEOFABRIK_URL below as well.
REGION=de

# ── Result / routing options ─────────────────────────────────────────────────
# Default result language (Photon `lang`), e.g. de, en, fr.
DEFAULT_LANG=de
# OSRM routing profile: car, bicycle or foot. Changing this needs a graph
# rebuild (delete the osrm_data volume, then `docker compose up`).
OSRM_PROFILE=car
# Override the auto-derived Geofabrik .osm.pbf URL for a REGION not in the
# built-in map. Must point at an extract that COVERS AT LEAST the Photon area
# (OSRM coverage ⊇ Photon coverage — see the coverage rule in the README).
#GEOFABRIK_URL=

# ── Caching ──────────────────────────────────────────────────────────────────
# Cache lifetime in seconds for geocoding and routing lookups.
CACHE_TTL=86400
# The ONLY Redis knob. false (default) → filesystem cache, no extra service.
# true → starts the bundled redis service and caches there instead.
ENABLE_REDIS=false

# ── Security / browser access ────────────────────────────────────────────────
# Optional API key. Empty (default) leaves the API open. When set, every request
# except /health must send it via the "X-API-Key" header.
API_KEY=
# CORS origin(s) allowed for browser autocomplete. "*" allows any origin; set a
# concrete origin (or regex) to restrict it.
CORS_ALLOW_ORIGIN=*

# ── Plumbing — DO NOT EDIT ───────────────────────────────────────────────────
# Maps ENABLE_REDIS onto a Compose profile so the redis service (tagged
# profiles: ["true"]) starts only when ENABLE_REDIS=true. This is wiring, not a
# knob — change ENABLE_REDIS above, never this line.
COMPOSE_PROFILES=${ENABLE_REDIS:-false}

# ── Advanced — upstream URLs ─────────────────────────────────────────────────
# Under Docker Compose the gateway already points at the in-cluster services, so
# you can ignore these. Set them only for a bare-metal gateway that talks to
# Photon/OSRM running elsewhere.
#PHOTON_URL=http://photon:2322
#OSRM_URL=http://osrm:5000
